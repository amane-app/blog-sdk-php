{
    "name": "amane/blog-sdk",
    "description": "AMANE Blog Distribution API SDK for PHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.3 || ^8.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Amane\\BlogSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Amane\\BlogSdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:unit": "phpunit --testsuite Unit --no-coverage",
        "test:integration": "phpunit --testsuite Integration --no-coverage",
        "test:e2e": "phpunit --testsuite E2E --no-coverage",
        "test:coverage": "phpunit --coverage-clover build/logs/clover.xml --coverage-text",
        "coverage:check": "php bin/coverage-check.php build/logs/clover.xml 90"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
